# ==========================================
# 应用配置
# ==========================================

APP_NAME="Personal Blog"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Shanghai
APP_URL=http://localhost

# 本地化
APP_LOCALE=zh_CN
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=zh_CN

# 维护模式
APP_MAINTENANCE_DRIVER=file

# ==========================================
# 日志配置
# ==========================================

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ==========================================
# 数据库配置
# ==========================================

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=blog
DB_USERNAME=root
DB_PASSWORD=

# ==========================================
# 会话配置
# ==========================================

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ==========================================
# 广播配置
# ==========================================

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# ==========================================
# 缓存配置
# ==========================================

CACHE_STORE=file
CACHE_PREFIX=blog_

# ==========================================
# 邮件配置
# ==========================================

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ==========================================
# AWS S3 配置（可选）
# ==========================================

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ==========================================
# Pusher 配置（可选，用于实时功能）
# ==========================================

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# ==========================================
# 博客配置 - 基础信息
# ==========================================

# 博客名称
BLOG_NAME="我的博客"
BLOG_DESCRIPTION="一个使用 Laravel 构建的个人博客"

# 博主信息
BLOG_AUTHOR_NAME="博主"
BLOG_AUTHOR_EMAIL="admin@example.com"
BLOG_AUTHOR_BIO="热爱技术，热爱生活"

# 分页设置
BLOG_PER_PAGE=10

# ==========================================
# 博客配置 - 评论设置
# ==========================================

# 是否开启评论
BLOG_COMMENTS_ENABLED=true

# 评论是否需要审核才显示
BLOG_COMMENTS_REQUIRE_APPROVAL=true

# 是否允许匿名评论
BLOG_COMMENTS_ALLOW_ANONYMOUS=true

# 评论最大嵌套层数
BLOG_COMMENTS_MAX_DEPTH=3

# ==========================================
# 博客配置 - 订阅设置
# ==========================================

# 是否开启邮件订阅
BLOG_SUBSCRIPTION_ENABLED=true

# 订阅是否需要验证邮箱
BLOG_SUBSCRIPTION_REQUIRE_CONFIRMATION=true

# ==========================================
# 博客配置 - 文章设置
# ==========================================

# 文章摘要长度
BLOG_EXCERPT_LENGTH=200

# 封面图尺寸
BLOG_COVER_IMAGE_WIDTH=1200
BLOG_COVER_IMAGE_HEIGHT=630

# ==========================================
# 博客配置 - SEO 设置
# ==========================================

# SEO 标题分隔符
BLOG_SEO_TITLE_SEPARATOR="|"

# SEO 关键词
BLOG_SEO_KEYWORDS="Laravel,博客,PHP"

# 默认 Open Graph 图片
BLOG_SEO_DEFAULT_OG_IMAGE=

# Google Site Verification
BLOG_GOOGLE_SITE_VERIFICATION=

# ==========================================
# 博客配置 - 缓存设置（TTL 以秒为单位）
# ==========================================

# 最新文章缓存
BLOG_CACHE_RECENT_POSTS_TTL=900

# 热门文章缓存
BLOG_CACHE_POPULAR_POSTS_TTL=900

# 分类缓存
BLOG_CACHE_CATEGORIES_TTL=3600

# 标签缓存
BLOG_CACHE_TAGS_TTL=3600

# 侧边栏缓存
BLOG_CACHE_SIDEBAR_TTL=900

# 文章缓存
BLOG_CACHE_POST_TTL=900

# HTML 渲染缓存
BLOG_CACHE_HTML_TTL=3600

# 订阅源缓存
BLOG_CACHE_FEED_TTL=3600

# 网站地图缓存
BLOG_CACHE_SITEMAP_TTL=3600

# ==========================================
# 博客配置 - 社交链接
# ==========================================

BLOG_SOCIAL_GITHUB=
BLOG_SOCIAL_TWITTER=
BLOG_SOCIAL_WEIBO=

# ==========================================
# 第三方服务配置
# ==========================================

# Google Analytics
GA_MEASUREMENT_ID=
GA_API_SECRET=

# ==========================================
# 安全配置
# ==========================================

# 强制 HTTPS（通过中间件或 web 服务器实现）
FORCE_HTTPS=false

# 密码重置 Token 过期时间（分钟）
PASSWORD_RESET_TOKEN_EXPIRE=60

# 邮箱验证 Token 过期时间（分钟）
EMAIL_VERIFY_TOKEN_EXPIRE=60

# ==========================================
# 速率限制配置
# ==========================================

# 登录尝试次数
RATE_LIMIT_MAX_ATTEMPTS=5

# 登录锁定时间（分钟）
RATE_LIMIT_DECAY_MINUTES=15

# 路由速率限制（次数,分钟）
# 例如：throttle:3,5 表示 5 分钟内最多 3 次请求